# ── MySQL ──
MYSQL_HOST=your_server_ip
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_METRICS_DB=JT-METRICS
MYSQL_F1_DB=JT-F1

# ── Home Assistant ──
# Generate a Long-Lived Access Token in HA: Profile → Security → Long-Lived Access Tokens
 HA_URL=http://your_server_ip:8123
HA_TOKEN=your_ha_long_lived_access_token

# ── AdGuard Home ──
ADGUARD_URL=http://your_server_ip:3000
ADGUARD_USER=your_adguard_user
ADGUARD_PASSWORD=your_adguard_password

# ── Plex ──
# Find your token: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_URL=http://your_server_ip:32400
PLEX_TOKEN=your_plex_token

# ── Frigate ──
FRIGATE_URL=http://your_server_ip:5000

# ── Weather (Open-Meteo, no key needed) ──
# Set to your location coordinates
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060

# ── Finance ──
# Comma-separated stock symbols and CoinGecko coin IDs
FINANCE_STOCKS=AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA,SPY,QQQ
FINANCE_CRYPTOS=bitcoin,ethereum,solana,cardano,dogecoin

# ── News (comma-separated RSS feed URLs) ──
# Leave blank to use defaults (Ars Technica, r/formula1, r/homeassistant, Hacker News)
# NEWS_FEEDS=https://feeds.arstechnica.com/arstechnica/index,https://hnrss.org/frontpage

# ── Server ──
SERVER_HOST=your_server_ip
